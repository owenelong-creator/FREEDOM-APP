rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'owenelong@gmail.com';
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function underSizeLimit() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    // Community images: posts/{uid}/{filename} and comments/{uid}/{filename}
    match /community/{scope}/{uid}/{fileName} {
      allow read: if true;
      allow create, update: if isSignedIn()
                            && request.auth.uid == uid
                            && (scope == 'posts' || scope == 'comments')
                            && isImage()
                            && underSizeLimit();
      allow delete: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
  }
}
