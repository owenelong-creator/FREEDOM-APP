rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'owenelong@gmail.com';
    }

    function isBanned() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/bans/$(request.auth.uid));
    }

    // ---- Profiles ----
    match /profiles/{uid} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == uid;
      allow delete: if isAdmin();
    }

    // ---- Username history ----
    match /usernameHistory/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // ---- Community posts ----
    match /communityPosts/{postId} {
      allow read: if true;

      // Any signed-in non-banned user can post as themselves.
      allow create: if isSignedIn()
                    && !isBanned()
                    && request.resource.data.uid == request.auth.uid;

      // Owner can edit (uid must stay the same).
      // Anyone signed in can update reactions only.
      // Admin can do anything.
      allow update: if isAdmin()
                    || (isSignedIn()
                        && resource.data.uid == request.auth.uid
                        && request.resource.data.uid == resource.data.uid)
                    || (isSignedIn()
                        && request.resource.data.diff(resource.data)
                              .affectedKeys().hasOnly(['reactions']));

      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.uid == request.auth.uid);

      // ---- Comments under each post ----
      match /comments/{commentId} {
        allow read: if true;

        allow create: if isSignedIn()
                      && !isBanned()
                      && request.resource.data.uid == request.auth.uid;

        allow update: if isAdmin()
                      || (isSignedIn()
                          && resource.data.uid == request.auth.uid
                          && request.resource.data.uid == resource.data.uid);

        allow delete: if isAdmin()
                      || (isSignedIn() && resource.data.uid == request.auth.uid);
      }
    }

    // ---- Reports (admin-reviewed) ----
    match /reports/{reportId} {
      allow create: if isSignedIn()
                    && request.resource.data.reporterUid == request.auth.uid;
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // ---- Bans (admin-managed) ----
    match /bans/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
