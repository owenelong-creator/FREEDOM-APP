rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- Users --------
    // Each signed-in user can read & write only their own user doc.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // -------- Posts --------
    // Anyone signed in can read the feed and create a post.
    // Only the author (matched by uid on the doc) can edit or delete it.
    match /posts/{postId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 280;

      allow update: if request.auth != null && (
        // Author can edit their own post.
        resource.data.uid == request.auth.uid
        // OR anyone signed in can update only the `reactions` map (for ❤️ 🔥 etc).
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
      );

      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;

      // -------- Comments (subcollection of posts) --------
      match /comments/{commentId} {
        allow read: if request.auth != null;

        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.message is string
          && request.resource.data.message.size() > 0
          && request.resource.data.message.size() <= 280;

        allow update, delete: if request.auth != null
          && resource.data.uid == request.auth.uid;
      }
    }

    // -------- Reports --------
    // Any signed-in user can file a report. Reports are write-only from the
    // client; reading/triaging happens in the Firebase Console.
    match /reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
