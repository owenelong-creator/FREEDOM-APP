rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'owenelong@gmail.com';
    }

    function isBanned() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/bans/$(request.auth.uid));
    }

    // ---- Profiles ----
    match /profiles/{uid} {
      allow read: if true;
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if isAdmin();
    }

    // ---- Username history (cooldown enforcement) ----
    match /usernameHistory/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // ---- Community posts ----
    match /communityPosts/{postId} {
      allow read: if true;

      allow create: if isSignedIn()
                    && !isBanned()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.message is string
                    && request.resource.data.message.size() <= 280
                    && (
                      !('imageUrl' in request.resource.data) ||
                      request.resource.data.imageUrl == null ||
                      request.resource.data.imageUrl is string
                    );

      allow update: if isSignedIn() && (
        // Owner can edit their own message + image
        (resource.data.uid == request.auth.uid
          && request.resource.data.uid == resource.data.uid)
        // Anyone signed in can update reactions only
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']))
        // Admin override
        || isAdmin()
      );

      allow delete: if isSignedIn() && (
        resource.data.uid == request.auth.uid || isAdmin()
      );

      // ---- Comments ----
      match /comments/{commentId} {
        allow read: if true;

        allow create: if isSignedIn()
                      && !isBanned()
                      && request.resource.data.uid == request.auth.uid
                      && request.resource.data.message is string
                      && request.resource.data.message.size() <= 280;

        allow update: if isSignedIn() && (
          (resource.data.uid == request.auth.uid
            && request.resource.data.uid == resource.data.uid)
          || isAdmin()
        );

        allow delete: if isSignedIn() && (
          resource.data.uid == request.auth.uid || isAdmin()
        );
      }
    }

    // ---- Reports ----
    match /reports/{reportId} {
      allow create: if isSignedIn()
                    && request.resource.data.reporterUid == request.auth.uid;
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // ---- Bans ----
    match /bans/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }
  }
}
