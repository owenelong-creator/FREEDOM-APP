rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'owenelong@gmail.com';
    }

    // True if the signed-in user has an active ban or suspension.
    // A ban with no expiresAt (or expiresAt in the future) is active.
    function isBanned() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/bans/$(request.auth.uid))
        && (
          !('expiresAt' in get(/databases/$(database)/documents/bans/$(request.auth.uid)).data)
          || get(/databases/$(database)/documents/bans/$(request.auth.uid)).data.expiresAt == null
          || get(/databases/$(database)/documents/bans/$(request.auth.uid)).data.expiresAt > request.time
        );
    }

    // ---- Profiles ----
    match /profiles/{uid} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == uid;
      allow delete: if isAdmin();
    }

    // ---- Username history ----
    match /usernameHistory/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // ---- Community posts ----
    match /communityPosts/{postId} {
      allow read: if true;

      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && !isBanned();

      allow update: if isAdmin()
                    || (isSignedIn()
                        && resource.data.uid == request.auth.uid
                        && request.resource.data.uid == resource.data.uid
                        && !isBanned())
                    || (isSignedIn()
                        && request.resource.data.diff(resource.data)
                              .affectedKeys().hasOnly(['reactions']));

      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.uid == request.auth.uid);

      // ---- Comments ----
      match /comments/{commentId} {
        allow read: if true;

        allow create: if isSignedIn()
                      && request.resource.data.uid == request.auth.uid
                      && !isBanned();

        allow update: if isAdmin()
                      || (isSignedIn()
                          && resource.data.uid == request.auth.uid
                          && request.resource.data.uid == resource.data.uid
                          && !isBanned());

        allow delete: if isAdmin()
                      || (isSignedIn() && resource.data.uid == request.auth.uid);
      }
    }

    // ---- Reports ----
    match /reports/{reportId} {
      allow create: if isSignedIn()
                    && request.resource.data.reporterUid == request.auth.uid;
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // ---- Bans / Suspensions (admin only writes) ----
    match /bans/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
